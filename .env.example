# ============ 后端配置 ============

# 数据库
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/1xbet-platform

# 服务器
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# ============ Stripe 支付 ============
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLIC_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============ USDT TRC20 ============
TRON_API_KEY=your-tron-api-key
TRON_NETWORK_RPC=https://api.trongrid.io

# ============ 支付宝 ============
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=your-public-key

# ============ 微信支付 ============
WECHAT_MCH_ID=your-merchant-id
WECHAT_API_KEY=your-api-key
WECHAT_APP_ID=your-app-id

# ============ ABA Pay (柬埔寨) ============
ABA_MERCHANT_ID=your-merchant-id
ABA_API_KEY=your-api-key

# ============ 银行账户（现金充值） ============
BANK_NAME=ABC Bank
BANK_ACCOUNT_NAME=Platform Account
BANK_ACCOUNT_NUMBER=123456789
BANK_ROUTING_NUMBER=000000000

# ============ JWT ============
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRE=7d

# ============ 邮件配置 ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ============ Telegram Bot ============
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ 文件上传 ============
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ============ 安全 ============
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
